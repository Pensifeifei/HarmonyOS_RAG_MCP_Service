# === HarmonyOS RAG MCP Service Configuration ===

# [REQUIRED] Absolute path to the upstream cleaned Markdown docs directory.
DOCS_SOURCE_PATH=/path/to/your/harmonyos_docs

# [OPTIONAL] Local ChromaDB persistent storage path. Default: ./chroma_data
CHROMA_STORAGE_PATH=./chroma_data

# [OPTIONAL] Local embedding model name (HuggingFace model ID).
# Recommended: BAAI/bge-large-zh-v1.5 or BAAI/bge-m3
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5

# [OPTIONAL] ChromaDB collection name. Default: harmonyos_docs
CHROMA_COLLECTION_NAME=harmonyos_docs

# [OPTIONAL] Log level. Options: DEBUG, INFO, WARNING, ERROR. Default: INFO
LOG_LEVEL=INFO
